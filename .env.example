# Telegram Bot
# Create a bot via @BotFather on Telegram to get the token
TELEGRAM_BOT_TOKEN=
# Your Telegram user ID (message @userinfobot to find it)
TELEGRAM_USER_ID=

# DigitalOcean
# Generate at https://cloud.digitalocean.com/account/api/tokens
DO_TOKEN=
# Region: ams3 (Amsterdam), nyc1 (New York), sfo3 (San Francisco), etc.
DO_REGION=ams3
# Droplet size ($6/mo = ~$0.009/hr)
DO_SIZE=s-1vcpu-1gb
# SSH key fingerprint (find at https://cloud.digitalocean.com/account/security)
SSH_KEY_FINGERPRINT=
# Path to your SSH private key (used to verify OpenVPN after boot)
SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa

# Naming
SNAPSHOT_PREFIX=openvpn-server
DROPLET_TAG=openvpn
DROPLET_NAME=openvpn-server

# OpenVPN
VPN_PORT=443
VPN_PROTO=tcp

# DNS (domain must point nameservers to ns1/ns2/ns3.digitalocean.com)
DNS_DOMAIN=myvpn.xyz
DNS_SUBDOMAIN=vpn
